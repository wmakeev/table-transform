{
  "name": "@wmakeev/table-transform",
  "version": "9.0.0-18",
  "type": "module",
  "description": "Streaming table data transformation",
  "keywords": [
    "csv",
    "table",
    "convert",
    "transform",
    "stream",
    "etl"
  ],
  "exports": "./build/src/index.js",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "files": [
    "build/src/"
  ],
  "scripts": {
    "lint": "eslint . --fix",
    "cleanup": "rm -rf build/",
    "compile:dev": "tsc",
    "compile": "tsc --build tsconfig.prod.json",
    "build:dev": "npm run lint && npm run compile:dev",
    "build": "npm run cleanup && npm run lint && npm run compile",
    "test": "npm run build && node --env-file=.env --test \"build/**/*.test.js\" --test-reporter=spec",
    "version": "auto-changelog -p && git add CHANGELOG.md",
    "release": "np"
  },
  "engines": {
    "node": ">=18"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "quoteProps": "consistent",
    "trailingComma": "none",
    "arrowParens": "avoid"
  },
  "np": {
    "yarn": false
  },
  "author": "Vitaly V. Makeev",
  "repository": {
    "type": "git",
    "url": "https://github.com/wmakeev/table-transform"
  },
  "license": "ISC",
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24",
    "@eslint/js": "^9.24.0",
    "@wmakeev/filtrex": "^6.4.0",
    "auto-changelog": "^2.4.0",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "decode-html": "^2.0.0",
    "envalid": "^8.1.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "lodash": "^4.17.21",
    "prettier": "^3.8.1",
    "simplex-lang": "^0.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.30.0"
  }
}
